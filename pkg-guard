#!/usr/bin/env python3
"""
pkg-guard: Local registry proxy that blocks too-young package versions.

Sits between pip/uv/npm and upstream registries, filtering out package
versions published fewer than N days ago. Supports vuln bypass via OSV.dev
and a package allowlist.

Usage:
    pkg-guard serve          Run the proxy server (foreground)
    pkg-guard start          Install and start launchd agent
    pkg-guard stop           Stop and uninstall launchd agent
    pkg-guard status         Show proxy status and config
    pkg-guard allow <pkg>    Add package to allowlist
    pkg-guard deny <pkg>     Remove package from allowlist
    pkg-guard log            Tail the log file
    pkg-guard check <pkg>    Check a PyPI package's age
    pkg-guard setup          Configure pip/uv/npm to use the proxy
    pkg-guard unsetup        Remove proxy config from pip/uv/npm
"""

