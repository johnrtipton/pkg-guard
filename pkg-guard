def main():
    parser = argparse.ArgumentParser(
        prog="pkg-guard",
        description="Local registry proxy that blocks too-young package versions.",
    )
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("serve", help="Run the proxy server (foreground)")
    sub.add_parser("start", help="Install and start launchd agent")
    sub.add_parser("stop", help="Stop and uninstall launchd agent")
    sub.add_parser("status", help="Show proxy status and config")
    sub.add_parser("setup", help="Configure pip/uv/npm to use the proxy")
    sub.add_parser("unsetup", help="Remove proxy config from pip/uv/npm")
    sub.add_parser("log", help="Tail the log file")

    p_allow = sub.add_parser("allow", help="Add package to allowlist")
    p_allow.add_argument("package")

    p_deny = sub.add_parser("deny", help="Remove package from allowlist")
    p_deny.add_argument("package")

    p_check = sub.add_parser("check", help="Check a package's version age")
    p_check.add_argument("package")

    args = parser.parse_args()
    cfg = load_config()

    match args.command:
        case "serve":
            run_server(cfg)
        case "start":
            cmd_start(cfg)
        case "stop":
            cmd_stop(cfg)
        case "status":
            cmd_status(cfg)
        case "setup":
            cmd_setup(cfg)
        case "unsetup":
            cmd_unsetup(cfg)
        case "log":
            cmd_log(cfg)
        case "allow":
            cmd_allow(cfg, args.package)
        case "deny":
            cmd_deny(cfg, args.package)
        case "check":
            cmd_check(cfg, args.package)
        case _:
            parser.print_help()


if __name__ == "__main__":
    main()
