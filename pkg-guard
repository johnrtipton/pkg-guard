def cmd_check(cfg: dict, pkg: str):
    """Check a PyPI package's latest version age."""
    min_age = cfg["guard"]["min_age_days"]
    try:
        url = f"https://pypi.org/pypi/{pkg}/json"
        body, _ = fetch_url(url)
        data = json.loads(body)
    except Exception as e:
        print(f"\033[0;31m✗ Could not fetch '{pkg}': {e}\033[0m")
        return

    version = data.get("info", {}).get("version", "")
    files = data.get("urls", [])
    upload_time = ""
    if files:
        upload_time = files[0].get("upload_time_iso_8601", "")

    age = version_age_days(upload_time)
    if age < 0:
        print(f"\033[0;33m⚠  Could not determine age for {pkg}=={version}\033[0m")
    elif age < min_age:
        print(f"\033[0;31m🛡  {pkg}=={version} is {age} day(s) old (threshold: {min_age}d) — BLOCKED\033[0m")
        # Find safe fallback
        releases = data.get("releases", {})
        candidates = []
        for ver, rfiles in releases.items():
            if not rfiles or is_prerelease(ver):
                continue
            ts = rfiles[0].get("upload_time_iso_8601", "")
            a = version_age_days(ts)
            if a >= min_age:
                candidates.append((version_sort_key(ver), ver, a))
        if candidates:
            candidates.sort(reverse=True)
            safe = candidates[0]
            print(f"\033[0;36m    Newest safe: {pkg}=={safe[1]} ({safe[2]} days old)\033[0m")
    else:
        print(f"\033[0;32m✓  {pkg}=={version} is {age} day(s) old — OK\033[0m")


