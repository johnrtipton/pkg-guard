def cmd_setup(cfg: dict):
    """Configure pip, uv, and npm to use the proxy."""
    host = cfg["server"]["host"]
    port = cfg["server"]["port"]
    proxy_url = f"http://{host}:{port}"

    # pip — merge with existing config
    pip_conf = pathlib.Path("~/.config/pip/pip.conf").expanduser()
    pip_conf.parent.mkdir(parents=True, exist_ok=True)
    pip_lines = [
        f"index-url = {proxy_url}/pypi/simple/",
        f"trusted-host = {host}",
    ]
    if pip_conf.exists():
        existing = pip_conf.read_text()
        if proxy_url in existing:
            print("  pip: already configured")
        else:
            shutil.copy2(pip_conf, pip_conf.with_suffix(".conf.bak"))
            # Remove existing index-url/trusted-host lines, preserve everything else
            lines = existing.splitlines()
            filtered = [l for l in lines if not re.match(r"^\s*(index-url|trusted-host)\s*=", l)]
            # Ensure [global] section exists
            if not any(re.match(r"^\[global\]", l) for l in filtered):
                filtered.insert(0, "[global]")
            # Insert our lines after [global]
            idx = next(i for i, l in enumerate(filtered) if re.match(r"^\[global\]", l))
            for j, line in enumerate(pip_lines):
                filtered.insert(idx + 1 + j, line)
            pip_conf.write_text("\n".join(filtered) + "\n")
            print(f"  pip: configured (backed up original to {pip_conf.with_suffix('.conf.bak')})")
    else:
        pip_conf.write_text("[global]\n" + "\n".join(pip_lines) + "\n")
        print("  pip: configured")

    # uv — merge with existing config
    uv_toml = pathlib.Path("~/.config/uv/uv.toml").expanduser()
    uv_toml.parent.mkdir(parents=True, exist_ok=True)
    uv_line = f'index-url = "{proxy_url}/pypi/simple/"'
    if uv_toml.exists():
        existing = uv_toml.read_text()
        if proxy_url in existing:
            print("  uv:  already configured")
        else:
            shutil.copy2(uv_toml, uv_toml.with_suffix(".toml.bak"))
            # Remove existing index-url, preserve everything else
            lines = [l for l in existing.splitlines() if not re.match(r"^\s*index-url\s*=", l)]
            lines.insert(0, uv_line)
            uv_toml.write_text("\n".join(lines) + "\n")
            print(f"  uv:  configured (backed up original to {uv_toml.with_suffix('.toml.bak')})")
    else:
        uv_toml.write_text(uv_line + "\n")
        print("  uv:  configured")

    # npm — preserve existing entries (like scoped registries)
    npmrc = pathlib.Path("~/.npmrc").expanduser()
    registry_line = f"registry={proxy_url}/npm/"
    if npmrc.exists():
        existing = npmrc.read_text()
        if proxy_url in existing:
            print(f"  npm: already configured")
        else:
            # Remove any existing top-level registry= line, add ours
            lines = existing.splitlines()
            new_lines = [l for l in lines if not re.match(r"^registry\s*=", l)]
            new_lines.insert(0, registry_line)
            shutil.copy2(npmrc, npmrc.with_suffix(".npmrc.bak"))
            npmrc.write_text("\n".join(new_lines) + "\n")
            print(f"  npm: configured (backed up original to {npmrc.with_suffix('.npmrc.bak')})")
    else:
        npmrc.write_text(registry_line + "\n")
        print(f"  npm: configured")

    print(f"\n\033[0;32m✓ All package managers configured to use proxy at {proxy_url}\033[0m")


def cmd_unsetup(cfg: dict):
    """Remove proxy config from pip, uv, and npm."""
    host = cfg["server"]["host"]
    port = cfg["server"]["port"]
    proxy_url = f"http://{host}:{port}"

    # pip — restore backup or remove
    pip_conf = pathlib.Path("~/.config/pip/pip.conf").expanduser()
    pip_bak = pip_conf.with_suffix(".conf.bak")
    if pip_conf.exists() and proxy_url in pip_conf.read_text():
        if pip_bak.exists():
            shutil.move(pip_bak, pip_conf)
            print("  pip: restored from backup")
        else:
            pip_conf.unlink()
            print("  pip: removed config")
    else:
        print("  pip: not configured (no change)")

    # uv — restore backup or remove
    uv_toml = pathlib.Path("~/.config/uv/uv.toml").expanduser()
    uv_bak = uv_toml.with_suffix(".toml.bak")
    if uv_toml.exists() and proxy_url in uv_toml.read_text():
        if uv_bak.exists():
            shutil.move(uv_bak, uv_toml)
            print("  uv:  restored from backup")
        else:
            uv_toml.unlink()
            print("  uv:  removed config")
    else:
        print("  uv:  not configured (no change)")

    # npm — remove registry line, keep the rest
    npmrc = pathlib.Path("~/.npmrc").expanduser()
    if npmrc.exists():
        existing = npmrc.read_text()
        if proxy_url in existing:
            lines = existing.splitlines()
            new_lines = [l for l in lines if proxy_url not in l]
            if new_lines:
                npmrc.write_text("\n".join(new_lines) + "\n")
            else:
                npmrc.unlink()
            print("  npm: removed proxy config")
        else:
            print("  npm: not configured (no change)")
    else:
        print("  npm: not configured (no change)")

    print(f"\n\033[0;32m✓ Proxy config removed\033[0m")


